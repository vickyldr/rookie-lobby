# 审稿/翻译机器人配置。复制成 .env 填好。
# 用【另一个】飞书自建应用（和答疑bot分开），凭证填这里：
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_DOMAIN=feishu

# 复用答疑bot那套中转（Claude 翻译 + whisper 转写都走它）
RELAY_URL=https://你的中转域名/v1/chat/completions
RELAY_KEY=你的中转key
RELAY_MODEL=claude-sonnet-4-6

# 语音转文字模型（在中转后台给 key 开通）；whisper-1 够用
WHISPER_MODEL=whisper-1
# 转写接口地址，不填就自动从 RELAY_URL 推出 /v1/audio/transcriptions
# WHISPER_URL=https://你的中转域名/v1/audio/transcriptions

# 视频翻译成什么语言
TARGET_LANG=中文
