# 审稿/翻译机器人配置。复制成 .env 填好。
# 用【另一个】飞书自建应用（和答疑bot分开），凭证填这里：
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_DOMAIN=feishu

# ===== AI 接口（两种任选一种）=====
# 代码会自动识别：URL 带 azure.com 就用 Azure 的 api-key 头，否则用标准 Bearer。

# 【A】标准 OpenAI 兼容中转：
# RELAY_URL=https://你的中转域名/v1/chat/completions
# RELAY_KEY=你的中转key
# RELAY_MODEL=gpt-4o-mini
# WHISPER_MODEL=whisper-1
# WHISPER_URL=   # 不填就自动从 RELAY_URL 推出 /v1/audio/transcriptions

# 【B】Azure OpenAI（公司提供；chat 和 whisper 是两个独立完整 URL，都要显式配）：
RELAY_URL=https://xxx.openai.azure.com/openai/deployments/gpt-4o-mini/chat/completions?api-version=2025-01-01-preview
RELAY_KEY=你的Azure密钥
RELAY_MODEL=gpt-4o-mini
# 优先用 transcriptions（原文+时间戳，直接原语言→中文，质量最好）；
# 若该 deployment 只开了 translations，就把 transcriptions 换成 translations（会先转英文再译中文，也能用）。
WHISPER_URL=https://xxx.openai.azure.com/openai/deployments/whisper/audio/transcriptions?api-version=2024-06-01
WHISPER_MODEL=whisper

# 视频翻译成什么语言
TARGET_LANG=中文
